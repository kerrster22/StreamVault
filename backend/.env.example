# StreamVault Backend — Environment Configuration
# Copy this to .env and adjust values

APP_ENV=development

# SQLite database path (inside container: /data/streamvault.db)
DATABASE_URL=sqlite:////data/streamvault.db

# Redis connection
REDIS_URL=redis://redis:6379

# Where downloaded media is stored (mounted volume)
MEDIA_ROOT=/media

# Temp dir for partial downloads
TEMP_DOWNLOAD_ROOT=/tmp/streamvault

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Optional: explicit paths if ffmpeg is not on PATH
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Optional: path to a Netscape-format cookies.txt file for authenticated yt-dlp extraction.
# Required for age-restricted, sign-in-required, or bot-check-protected YouTube videos.
# Export cookies from your browser using a browser extension (e.g. "Get cookies.txt LOCALLY"),
# place the file at ./cookies/cookies.txt on your host, and set this path to the in-container
# location. The container mounts ./cookies as read-only (:ro), which is safe — the app
# automatically copies the file to TEMP_DOWNLOAD_ROOT before passing it to yt-dlp, so
# yt-dlp's cookie-jar write-back never touches the read-only mount.
# YTDLP_COOKIES_FILE=/app/cookies/cookies.txt

# Skip the youtube:tab authentication pre-check for playlist/channel analysis.
# When true (the default), yt-dlp bypasses YouTube's "Playlists that require
# authentication may not extract correctly" gate, which blocks anonymous
# analysis of many public playlists. Disable only if you need strict auth
# enforcement and have valid cookies configured.
# YTDLP_SKIP_YOUTUBETAB_AUTHCHECK=true

# Writable temp directory used for partial downloads and yt-dlp cookie temp copies.
# Must be writable inside the container. Defaults to /tmp/streamvault.
# TEMP_DOWNLOAD_ROOT=/tmp/streamvault

# yt-dlp audio defaults
DEFAULT_AUDIO_FORMAT=mp3
DEFAULT_AUDIO_QUALITY=192

# Max entries to return in playlist/channel preview
MAX_ANALYZE_ENTRIES_PREVIEW=50
